# ShopMind AI — Environment Variables
# Copy this file to .env and fill in your values

# ============ SUPABASE ============
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============ n8n WEBHOOKS ============
# Chat pipeline webhook URL (handles: intent → RAG → GPT response)
VITE_N8N_CHAT_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/chat-request

# Voice pipeline webhook URL (handles: STT → chat pipeline → TTS)
VITE_N8N_VOICE_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/voice-processing

# File ingestion webhook URL (handles: download → extract → chunk → embed)
VITE_N8N_FILE_INGESTION_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/file-ingestion

# Billing webhook URL (handles: Stripe checkout/portal session creation)
VITE_N8N_BILLING_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/billing

# ============ STRIPE (client-side) ============
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============ OPTIONAL: Direct API Keys ============
# These are only needed if calling APIs directly from Edge Functions
# instead of through n8n. Do NOT expose secret keys in VITE_ variables.
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
# DEEPGRAM_API_KEY=...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
